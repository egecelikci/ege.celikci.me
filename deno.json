{
  "nodeModulesDir": "auto",
  "imports": {
    "@shikijs/rehype": "npm:@shikijs/rehype@^4.3.0",
    "@shikijs/themes": "npm:@shikijs/themes@^4.3.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.7",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/path": "jsr:@std/path@^1.1.5",
    "@std/yaml": "jsr:@std/yaml@^1.1.1",
    "@types/leaflet": "npm:@types/leaflet@^1.9.21",
    "instant.page": "npm:instant.page@^5.2.0",
    "leaflet": "npm:leaflet@^1.9.4",
    "lume/": "https://cdn.jsdelivr.net/gh/lumeland/lume@cde8072dda0b0518fd5342ea432049c9d3c0d49b/",
    "lume/jsx-runtime": "https://cdn.jsdelivr.net/gh/oscarotero/ssx@0.1.15/jsx-runtime.ts",
    "photoswipe": "npm:photoswipe@^5.4.4",
    "rehype-autolink-headings": "npm:rehype-autolink-headings@^7.1.0",
    "rehype-slug": "npm:rehype-slug@^6.0.0",
    "remark-gfm": "npm:remark-gfm@^4.0.1",
    "remark-smartypants": "npm:remark-smartypants@^3.0.2",
    "remark-toc": "npm:remark-toc@^9.0.0",
    "sanitize-html": "npm:sanitize-html@^2.17.5",
    "sharp": "npm:sharp@^0.35.2",
    "shiki": "npm:shiki@^4.3.0",
    "typst": "https://cdn.jsdelivr.net/gh/lumeland/experimental-plugins@74fe9bd69dc67854912d4d31ed9a65a7bf5d0198/typst/mod.ts",
    "workbox-cli": "npm:workbox-cli@^7.4.1"
  },
  "tasks": {
    "lume": {
      "description": "Run Lume command",
      "command": "deno run -A lume/cli.ts"
    },
    "build": {
      "description": "Build the site for production",
      "command": "MODE=production deno task lume"
    },
    "serve": {
      "description": "Run and serve the site for development",
      "command": "MODE=development deno task lume -s"
    },
    "deploy": {
      "description": "Build locally and publish to Netlify",
      "command": "deno task build && netlify deploy --prod"
    },
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "wasmbuild": "cd src/_rust/collage && deno run -A jsr:@deno/wasmbuild --inline --out lib",
    "new": {
      "description": "Create new content or code using artifacts",
      "command": "deno task lume new"
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "include": [
      "src/",
      "_config/",
      "utils/",
      "netlify/",
      "*.ts",
      "*.json",
      "*.md",
      "*.yml",
      "*.css"
    ],
    "exclude": [
      "src/_data/music.json",
      "src/_data/mb_events.json"
    ]
  },
  "compilerOptions": {
    "types": ["lume/types.ts"],
    "jsx": "react-jsx",
    "jsxImportSource": "lume"
  },
  "unstable": ["temporal", "fmt-component"],
  "lint": {
    "plugins": ["https://cdn.jsdelivr.net/gh/lumeland/lume@3.2.6/lint.ts"],
    "rules": {
      "exclude": ["no-import-prefix"]
    }
  },
  "lock": false,
  "permissions": {
    "lume": {
      "read": true,
      "write": ["./"],
      "import": [
        "cdn.jsdelivr.net:443",
        "jsr.io:443",
        "deno.land:443",
        "esm.sh:443"
      ],
      "net": [
        "0.0.0.0",
        "cdn.jsdelivr.net:443",
        "data.jsdelivr.com:443",
        "jsr.io:443",
        "deno.land:443",
        "esm.sh:443",
        "registry.npmjs.org:443"
      ],
      "env": true,
      "run": true,
      "ffi": true,
      "sys": true
    }
  },
  "allowScripts": ["npm:sharp"]
}
