{
  "nodeModulesDir": "auto",
  "imports": {
    "@shikijs/rehype": "npm:@shikijs/rehype@^4.0.2",
    "@shikijs/themes": "npm:@shikijs/themes@^4.0.2",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/crypto": "jsr:@std/crypto@^1.1.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "cssnano": "npm:cssnano@^7.1.7",
    "gsap": "npm:gsap@^3.15.0",
    "leaflet": "npm:leaflet@^1.9.4",
    "@types/leaflet": "npm:@types/leaflet@^1.9.21",
    "photoswipe": "npm:photoswipe@^5.4.4",
    "instant.page": "npm:instant.page@^5.2.0",
    "lume/": "https://cdn.jsdelivr.net/gh/lumeland/lume@3.2.4/",
    "lume/cms/": "https://cdn.jsdelivr.net/gh/lumeland/cms@0.15.0/",
    "lume/jsx-runtime": "https://cdn.jsdelivr.net/gh/oscarotero/ssx@0.1.14/jsx-runtime.ts",
    "make-fetch-happen": "npm:make-fetch-happen@^15.0.5",
    "rehype-autolink-headings": "npm:rehype-autolink-headings@^7.1.0",
    "rehype-slug": "npm:rehype-slug@^6.0.0",
    "remark-gfm": "npm:remark-gfm@^4.0.1",
    "remark-smartypants": "npm:remark-smartypants@^3.0.2",
    "remark-toc": "npm:remark-toc@^9.0.0",
    "remark-wiki-link": "npm:remark-wiki-link@^2.0.1",
    "sanitize-html": "npm:sanitize-html@^2.17.3",
    "sharp": "npm:sharp@^0.34.5",
    "shiki": "npm:shiki@^4.0.2",
    "workbox-cli": "npm:workbox-cli@^7.4.0"
  },
  "tasks": {
    "lume": {
      "description": "Run Lume command",
      "command": "deno run -A _lume.ts"
    },
    "build": {
      "description": "Build the site for production",
      "command": "MODE=production deno task lume"
    },
    "serve": {
      "description": "Run and serve the site for development",
      "command": "MODE=development deno task lume -s"
    },
    "deploy": {
      "description": "Build locally and publish to Netlify",
      "command": "deno task build && netlify deploy --prod"
    },
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "wasmbuild": "cd src/_rust/collage && deno run -A jsr:@deno/wasmbuild --inline --out lib",
    "fetch-music": "deno run --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-run utils/fetch-music.ts",
    "fetch-events": "deno run --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-run utils/fetch-events.ts"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "include": [
      "src/",
      "_config/",
      "utils/",
      "netlify/",
      "*.ts",
      "*.json",
      "*.md",
      "*.yml",
      "*.css"
    ],
    "exclude": [
      "src/site.webmanifest.vto"
    ]
  },
  "compilerOptions": {
    "types": [
      "lume/types.ts"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "lume"
  },
  "unstable": [
    "temporal",
    "fmt-component"
  ],
  "lint": {
    "plugins": [
      "https://cdn.jsdelivr.net/gh/lumeland/lume@3.2.4/lint.ts"
    ],
    "rules": {
      "exclude": [
        "no-import-prefix"
      ]
    }
  },
  "lock": false,
  "permissions": {
    "lume": {
      "read": true,
      "write": [
        "./"
      ],
      "import": [
        "cdn.jsdelivr.net:443",
        "jsr.io:443",
        "deno.land:443",
        "esm.sh:443"
      ],
      "net": [
        "0.0.0.0",
        "cdn.jsdelivr.net:443",
        "data.jsdelivr.com:443",
        "jsr.io:443",
        "deno.land:443",
        "esm.sh:443",
        "registry.npmjs.org:443"
      ],
      "env": true,
      "run": true,
      "ffi": true,
      "sys": true
    }
  },
  "allowScripts": [
    "npm:sharp"
  ]
}
