---
url: /site.webmanifest
layout: null
templateEngine: [vto]
---
{{ set defaultTheme = themes.find((t) => t.id === "default") }}
{
  "lang": "{{ site.lang }}",
  "dir": "ltr",
  "name": "{{ author.name }}",
  "short_name": "{{ site.title }}",
  "description": "{{ site.description }}",
  "icons": [
    {
      "src": "/assets/images/favicon/android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/assets/images/favicon/android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "display_override": ["window-controls-overlay"],
  "theme_color": "#a60c49",
  "background_color": "#fef6e4",
  "start_url": "/",
  "display": "standalone",
  "orientation": "natural"
}
