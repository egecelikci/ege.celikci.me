---
layout: layouts/page.vto
---
<div class="[view-transition-name:bookmarks-layout]">
  {{
    await comp.features.Bookmarks({
      filteredBookmarks: it.filteredBookmarks,
      allCategoryIds: it.allCategoryIds,
      categoryMetadata: it.categoryMetadata,
      activeCategory: it.activeCategory,
      totalCount: it.totalCount,
      search_bar: it.search_bar,
    })
  }}
</div>
