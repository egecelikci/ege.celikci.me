<!DOCTYPE html>
<html lang="{{ site.lang }}" class="{{ htmlClass }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fef6e4" />

    <meta
      name="theme-color"
      content="#463366"
      media="(prefers-color-scheme: dark)"
    />
    <title>
      {{ if title && title !== site.title }}{{ title }} | {{ site.title }}{{
        else
      }}{{ site.title }}{{ /if }}
    </title>
    <link rel="dns-prefetch" href="https://webmention.io" />
    <link
      rel="preload"
      href="/assets/fonts/josefin-sans-normal-100-700-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/assets/fonts/inconsolata-100-normal-200-900-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/assets/fonts/inconsolata-100-normal-200-900-latin-ext.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    {{# 2. Critical Assets #}}
    <link rel="modulepreload" href="/assets/scripts/main.js">
    <link rel="stylesheet" href="/assets/styles/main.css" />

    {{ include "meta.vto" }}
  </head>
  <body
    class="overflow-x-clip print:bg-white print:text-black flex flex-col min-h-screen"
    {{ if it.disable_animation }}data-disable-animation="true"{{ /if }}
    {{ if it.searchable === false }}data-pagefind-ignore="all"{{ /if }}
  >
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:z-[9999] focus:left-1/2 focus:top-0 focus:text-base focus:-translate-x-1/2 bg-surface focus:text-white focus:rounded-b-lg focus:px-6 focus:py-4 focus:outline-none focus:whitespace-nowrap print:hidden"
    >skip to main content</a>

    {{ include "header.vto" }}

    <main id="main" role="main" tabindex="-1" class="flex-grow">
      {{ content |> safe }}
    </main>

    {{ await it.comp.ui.Footer({ page: page }) }}

    {{# Representative h-card (IndieWeb Identity Consolidation) #}}
    <div class="h-card hidden" aria-hidden="true">
      <a class="p-name u-url u-uid" rel="me" href="/">{{ author.name }}</a>
      <img class="u-photo" src="{{ author.avatar }}">
      <p class="p-note">{{ site.description }}</p>
      <a class="u-email" href="mailto:{{ author.email }}">{{ author.email }}</a>
    </div>

    {{# Hidden Verification Links (rel="me") managed by SocialLinks #}}
    {{ await it.comp.features.SocialLinks({ variant: "hidden" }) }}

    {{# Media Modal (Phanpy-style) #}}
    {{ await it.comp.ui.Litebox() }}

    <script type="module" src="/assets/scripts/main.js"></script>
  </body>
</html>
