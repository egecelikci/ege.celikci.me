<!DOCTYPE html>
<html lang="{{ site.lang }}" class="{{ htmlClass }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {{ set defaultTheme = themes.find((t) => t.id === "default") }}
    {{ set darkTheme = themes.find((t) => t.id === "dark") }}

    <meta name="theme-color" content="{{ defaultTheme.colors.background }}" />

    <meta
      name="theme-color"
      content="{{ darkTheme.colors.background }}"
      media="(prefers-color-scheme: dark)"
    />
    <title>
      {{ if title }}{{ title }} | {{ site.title }}{{ else }}{{ site.title }}{{
        /if
      }}
    </title>
    <link
      rel="preload"
      href="{{ '/assets/fonts/JosefinSans-VariableFont_wght.woff2' |> url }}"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="{{ '/assets/fonts/Inconsolata.woff2' |> url }}"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preconnect" href="https://ege.celikci.me" />
    <link rel="preconnect" href="https://webmention.io" />
    <link rel="modulepreload" href="/assets/scripts/main.js">
    <link rel="stylesheet" href="/assets/styles/main.css" inline />

    {{ include "meta.vto" }}
  </head>
  <body 
    class="overflow-x-hidden print:bg-white print:text-black flex flex-col min-h-screen" 
    {{ if it.disable_animation }}data-disable-animation="true"{{ /if }}
    {{ if it.searchable === false }}data-pagefind-ignore="all"{{ /if }}
  >
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:z-[9999] focus:left-1/2 focus:top-0 focus:text-base focus:-translate-x-1/2 bg-surface focus:text-white focus:rounded-b-lg focus:px-6 focus:py-4 focus:outline-none focus:whitespace-nowrap print:hidden"
    >skip to main content</a>

    {{ include "header.vto" }}

    <main id="main" role="main" tabindex="-1" class="flex-grow">
      {{ content |> safe }}
    </main>

    {{ comp.ui.Footer({ page: page }) }}

    {{# Representative h-card (IndieWeb Identity Consolidation) #}}
    <div class="h-card hidden" aria-hidden="true">
      <a class="p-name u-url u-uid" rel="me" href="/">{{ author.name }}</a>
      <img class="u-photo" src="{{ author.avatar }}">
      <p class="p-note">{{ site.description }}</p>
      <a class="u-email" href="mailto:{{ author.email }}">{{ author.email }}</a>
    </div>

    {{# Hidden Verification Links (rel="me") managed by SocialLinks #}}
    {{ comp.features.SocialLinks({ variant: "hidden" }) }}

    {{# Authentication Modal (Shared Identity Portal) #}}
    {{ comp.features.StatusAuth() }}

    <script type="module" src="/assets/scripts/main.js"></script>
  </body>
</html>
