<!DOCTYPE html>
<html lang="{{ site.lang }}" class="{{ htmlClass }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fef6e4" />

    <meta
      name="theme-color"
      content="#463366"
      media="(prefers-color-scheme: dark)"
    />
    <title>
      {{ if title && title !== site.title }}{{ title }} | {{ site.title }}{{
        else if type === "note"
      }}note from {{ it.date |> date("dd MMM yyyy HH:mm") }} | {{
          site.title
        }}{{ else }}{{ site.title }}{{ /if }}
    </title>
    <link rel="dns-prefetch" href="https://webmention.io" />
    <link
      rel="preload"
      href="/assets/fonts/dm-sans-normal-100-1000-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/assets/fonts/dm-sans-normal-100-1000-latin-ext.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <link
      rel="preload"
      href="/assets/fonts/dm-mono-normal-400-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    {{# 2. Critical Assets #}}
    <link rel="modulepreload" href="/assets/scripts/main.js">
    <link rel="stylesheet" href="/assets/styles/main.css" />

    {{ include "meta.vto" }}
  </head>
  <body
    class="overflow-x-clip print:bg-white print:text-black flex flex-col min-h-screen"
    {{ if it.disable_animation }}data-disable-animation="true"{{ /if }}
    {{ if it.searchable === false }}data-pagefind-ignore="all"{{ /if }}
  >
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:z-[9999] focus:left-1/2 focus:top-0 focus:text-base focus:-translate-x-1/2 bg-surface focus:text-white focus:rounded-b-lg focus:px-6 focus:py-4 focus:outline-none focus:whitespace-nowrap print:hidden"
    >skip to main content</a>

    {{ include "header.vto" }}

    <main id="main" tabindex="-1" class="flex-grow">
      {{ content |> safe }}
    </main>

    {{ await it.comp.layout.Footer({ page: page }) }}

    {{# Representative h-card (IndieWeb Identity Consolidation) #}}
    <div
      class="h-card hidden"
      aria-hidden="true"
      itemscope
      itemtype="https://schema.org/Person"
    >
      <a class="p-name u-url u-uid" rel="me" href="/" itemprop="url">
        <span itemprop="name">{{ author.name }}</span>
      </a>
      <img
        class="u-photo"
        src="{{ author.avatar }}"
        alt="{{ author.name }}"
        itemprop="image"
      >
      <p class="p-note" itemprop="description">{{ site.description }}</p>
      <a class="u-email" href="mailto:{{ author.email }}" itemprop="email">{{
        author.email
      }}</a>
    </div>

    {{# Hidden Verification Links (rel="me") managed by SocialLinks #}}
    {{ await it.comp.features.SocialLinks({ variant: "hidden" }) }}

    {{# Media Modal (Phanpy-style) #}}
    {{ await it.comp.ui.Lightbox() }}

    <script type="module" src="/assets/scripts/main.js"></script>
  </body>
</html>
