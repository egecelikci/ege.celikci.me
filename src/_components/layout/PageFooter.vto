{{#
  Component: PageFooter
  A unified, robust footer for content pages.

  Props:
    - interactions: Array of webmention objects
    - stats: { replies: number, reposts: number, likes: number }
    - syndication: { bluesky?: string, mastodon?: string }
    - related: html (Related Content block)
    - backlinks: html (IncomingLinks block)
    - footerExtension: Object for custom footer meta content
    - show_webmentions: boolean (default: false)
#}}

{{# Resolve footer extension if it's an object #}}
{{ set extensionContent }}
  {{ if it.footerExtension }}
    {{ if it.footerExtension.comp }}
      {{ set resolvedComp = it.footerExtension.comp |> resolveComp(comp) }}
      {{ if resolvedComp }}
        {{ await resolvedComp({ ...it.footerExtension.props, ...author }) }}
      {{ /if }}
    {{ else }}
      {{ it.footerExtension |> safe }}
    {{ /if }}
  {{ /if }}
{{ /set }}

{{ set showInteractions = it.show_webmentions && it.interactions?.length > 0 }}
{{
  set showStats = it.show_webmentions && it.stats &&
  (it.stats.replies > 0 || it.stats.reposts > 0 || it.stats.likes > 0)
}}

{{
  set hasExtension = extensionContent && String(extensionContent).trim() !== ""
}}
{{ set hasRelated = it.related && String(it.related).trim() !== "" }}
{{ set hasBacklinks = it.backlinks && String(it.backlinks).trim() !== "" }}
{{
  set hasSyndication = it.syndication && (it.syndication.mastodon || it.syndication.bluesky)
}}
{{ set hasActivity = showInteractions || showStats || hasSyndication }}
{{ set hasMetaRow = hasExtension || hasActivity }}
{{ set shouldRenderFooter = hasMetaRow || hasRelated || hasBacklinks }}

{{ if shouldRenderFooter }}
  <footer
    class="mt-12 pt-6 border-t border-border-subtle flex flex-col gap-8 md:gap-12 print:hidden [view-transition-name:page-supplemental]"
  >
    {{# 1. Meta & Activity Row #}}
    {{ if hasMetaRow }}
      <div
        class="flex flex-col gap-6 md:gap-8 {{ if hasRelated || hasBacklinks }}pb-8 border-b border-border-subtle{{ /if }}"
      >
        {{ if hasExtension }}
          <div class="w-full">
            {{ extensionContent |> safe }}
          </div>
        {{ /if }}

        {{ if hasActivity }}
          {{# Row 1: [About Webmentions] | [syndication icons] #}}
          <div
            class="flex items-center justify-between gap-4 flex-wrap"
          >
            <div
              class="flex items-center gap-6 text-sm text-text-muted"
            >
              <div class="flex items-center gap-4">
                {{ if showInteractions }}
                  <span class="typography-sublabel text-text-muted">
                    {{ it.interactions.length }} {{ it.interactions.length == 1 ? "interaction" : "interactions" }}
                  </span>
                {{ /if }}

                {{ if showInteractions }}
                  <a
                    href="https://indieweb.org/Webmention"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 typography-sublabel text-text-muted hover:text-secondary transition-all duration-300 no-underline haptic"
                    title="Learn about Webmentions"
                  >
                    {{
                      await it.comp.base.Icon({
                        name: "badge-question-mark",
                        catalog: "lucide",
                        classes: "w-3.5 h-3.5 stroke-[1.5]",
                      })
                    }}
                    What’s this?
                  </a>
                {{ /if }}
              </div>
            </div>

            <div class="shrink-0">
              {{
                await it.comp.ui.ActivityMeta({
                  stats: showInteractions ? null : it.stats,
                  syndication: it.syndication,
                })
              }}
            </div>
          </div>
          {{# Row 2: Faces #}}
          {{ if showInteractions }}
            <div id="interactions" class="-mt-2 md:-mt-4">
              {{ await it.comp.ui.WebmentionFaces({ mentions: it.interactions }) }}
            </div>
          {{ /if }}

          {{# Row 3: Comments #}}
          {{ if showInteractions }}
            <div>
              {{
                await it.comp.ui.WebmentionComments({
                  mentions: it.interactions,
                  classes: "mt-4",
                })
              }}
            </div>
          {{ /if }}
        {{ /if }}
      </div>
    {{ /if }}

    {{# 2. Supplemental Blocks #}}
    {{ if hasRelated || hasBacklinks }}
      <div class="flex flex-col gap-24">
        {{ if hasRelated }}
          <div id="related">
            {{ it.related |> safe }}
          </div>
        {{ /if }}

        {{ if hasBacklinks }}
          <div id="backlinks">
            {{ it.backlinks |> safe }}
          </div>
        {{ /if }}
      </div>
    {{ /if }}
  </footer>
{{ /if }}
