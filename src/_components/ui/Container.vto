{{#
  Universal Container Component
  Props:
    - width: "narrow" | "default" | "wide" | "full" | custom class
    - as: HTML tag (default: "div")
    - centered: boolean (default: true)
    - padding: boolean | string (default: true)
    - classes: additional classes
    - attributes: object of HTML attributes (e.g. { "aria-label": "nav" })
    - content: string (body)
#}}

{{ set tag = as || "div" }}

{{
  set widthClass = {
    "narrow": "max-w-3xl",
    "default": "max-w-6xl",
    "wide": "max-w-screen-2xl",
    "full": "max-w-full",
  }[width] || width || "max-w-6xl"
}}

{{
  set paddingClass = padding === false
  ? ""
  : (typeof padding === "string" ? padding : "px-4 md:px-0")
}}

{{
  set containerClasses = [
    "w-full",
    paddingClass,
    centered !== false ? "mx-auto" : "",
    widthClass,
    classes,
  ]
  |> join(" ")
  |> trim
}}

<{{ tag }}
class="{{ containerClasses }}"
{{ if attributes }}{{ attributes |> attr |> safe }}{{ /if }}
>
{{ content |> safe }}
</{{ tag }}>
